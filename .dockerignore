# Keep the Docker build context tight. The api-server image only needs the
# root Cargo.toml + the crates/ tree (api-server, common-wire). It does NOT
# need the React frontend, the cmtrace-wasm crate (which has a cross-repo
# path dep), node_modules, or any build output.

# Build artifacts
/target
/pkg
/dist
**/node_modules

# React frontend — not part of the api-server image
/src
/index.html
/package.json
/pnpm-lock.yaml
/vite.config.ts
/tsconfig.json
/public

# wasm crate — excluded from the root workspace, not buildable in this
# context anyway (depends on the cmtraceopen submodule).
/cmtrace-wasm

# cmtraceopen submodule — the api-server build doesn't need it (common-wire
# doesn't re-export LogEntry yet). Include it later when wire DTOs adopt
# parser types.
/cmtraceopen

# Ansible deploy kit — runs from the Mac control machine, not built into
# the api-server image.
/dev

# VCS + editor + OS
/.git
/.github
/.vscode
/.idea
**/.DS_Store
Thumbs.db
*.log

# Local dev convenience
/.claude
/.claude-dev-shell.ps1
/.env
/.env.local

# Root-level docs — not needed in the image
/CHANGELOG.md
/CONTRIBUTING.md
/LICENSE
/README.md

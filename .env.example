# Copy to `.env` (gitignored) and customize. docker-compose auto-loads .env.

# API server log filter (tracing EnvFilter syntax).
# Examples:
#   RUST_LOG=debug
#   RUST_LOG=api_server=debug,tower_http=debug,axum=info,warn
RUST_LOG=api_server=info,tower_http=info,axum=info,warn

# --- Operator bearer-token auth (Entra / Azure AD) -------------------------
# Query routes (/v1/devices, /v1/sessions/*) require an Entra-issued JWT.
# Ingest routes stay unauthenticated pending Wave 3 mTLS.
#
# Production: set all three CMTRACE_ENTRA_* vars; auth mode defaults to
# `enabled` and the server will refuse to start without them.
#
# Local dev: set CMTRACE_AUTH_MODE=disabled to bypass the extractor. This
# injects a synthetic principal on every request and is DEV-ONLY — never
# deploy with this flag.
#CMTRACE_AUTH_MODE=disabled
#CMTRACE_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
#CMTRACE_ENTRA_AUDIENCE=api://<api-client-id>
#CMTRACE_ENTRA_JWKS_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys

# --- mTLS termination + cert-derived device identity (Wave 3) -------------
# When CMTRACE_TLS_ENABLED=true the server terminates TLS itself
# (rustls + aws-lc-rs) and validates client certs against the bundle at
# CMTRACE_CLIENT_CA_BUNDLE. Ingest routes then derive `device_id` from
# the client cert's SAN URI (device://{tenant}/{aad-device-id}).
#
# The CA bundle is the Gell - PKI Root + Issuing PEM exported from Intune
# Cloud PKI per docs/provisioning/03-intune-cloud-pki.md.
#
# CMTRACE_MTLS_REQUIRE_INGEST=true (default when TLS is on) makes ingest
# 401 without a verified client cert. Set to `false` during the rollover
# from header-based identity to PKCS-issued certs.
#
# Default for the dev box is plaintext (no TLS); this section is
# commented out so `cargo run` keeps working with no extra setup.
#CMTRACE_TLS_ENABLED=true
#CMTRACE_TLS_CERT=/etc/cmtraceopen/certs/server.crt
#CMTRACE_TLS_KEY=/etc/cmtraceopen/certs/server.key
#CMTRACE_CLIENT_CA_BUNDLE=/etc/cmtraceopen/certs/client-ca.pem
#CMTRACE_MTLS_REQUIRE_INGEST=true
#CMTRACE_SAN_URI_SCHEME=device

# --- mTLS client-cert revocation (CRL polling) -----------------------------
# Comma-separated CRL distribution-point URLs. Both the Cloud PKI Root and
# Issuing CRLs should be listed so revocations at either tier are honored.
# Live URLs for the Gell tenant (see memory ref reference_cloud_pki.md):
#CMTRACE_CRL_URLS=http://primary-cdn.pki.azure.net/centralus/crls/9a8a2d279a7243fc96a508cbfca8f5d0/ad11b686-5970-42de-9827-91700269875b_v1/current.crl,http://primary-cdn.pki.azure.net/centralus/crls/9a8a2d279a7243fc96a508cbfca8f5d0/7ff044a8-9c28-4529-9d79-76bdb94df99d_v1/current.crl

# Refresh cadence in seconds. Default 3600 (1h) — matches Cloud PKI's
# typical publishing interval.
#CMTRACE_CRL_REFRESH_SECS=3600

# Fail-open vs fail-closed behaviour when no CRL has been fetched yet.
# Default `false` (fail-closed = secure). Set `true` ONLY for offline
# / air-gapped lab deployments and only with a compensating control
# (short leaf TTL, allow-listed device IDs, etc.).
#CMTRACE_CRL_FAIL_OPEN=false

# ---------------------------------------------------------------------------
# Web viewer (Vite) — copy these into `.env.local` (gitignored), not `.env`.
# Vite only exposes vars prefixed with VITE_ to client code.
# ---------------------------------------------------------------------------

# Base URL of the api-server. Empty = same-origin (uses Vite's dev proxy
# in development, or assumes the viewer is co-deployed with the api-server
# in production). Set this to a fully-qualified URL (e.g.
# "https://api.example.com") when the viewer is hosted on a different
# origin from the api-server.
VITE_CMTRACE_API_BASE=

# Entra (Azure AD) tenant ID — the GUID of the directory that owns the
# `cmtraceopen-viewer` SPA app registration. From Entra portal:
# App registrations → cmtraceopen-viewer → Overview → "Directory (tenant) ID".
VITE_ENTRA_TENANT_ID=

# Entra application (client) ID of the viewer SPA registration
# (`cmtraceopen-viewer`). From Entra portal:
# App registrations → cmtraceopen-viewer → Overview → "Application (client) ID".
VITE_ENTRA_CLIENT_ID=

# Full scope string the viewer requests when acquiring an access token for
# the api-server. Format: api://<api-client-id>/CmtraceOpen.Query
# Where <api-client-id> is the application (client) ID of the
# `cmtraceopen-api` registration (the protected-resource app).
# See docs/provisioning/02-entra-app-registration.md for the full setup.
VITE_ENTRA_API_SCOPE=

# When any of the three VITE_ENTRA_* vars above is empty, the viewer runs
# in **anonymous mode**: no MSAL initialization, no Authorization header
# attached to api-server requests. This works against api-server with
# CMTRACE_AUTH_MODE=disabled (dev bypass).

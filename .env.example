# Copy to `.env` (gitignored) and customize. docker-compose auto-loads .env.

# API server log filter (tracing EnvFilter syntax).
# Examples:
#   RUST_LOG=debug
#   RUST_LOG=api_server=debug,tower_http=debug,axum=info,warn
RUST_LOG=api_server=info,tower_http=info,axum=info,warn

# ---------------------------------------------------------------------------
# Web viewer (Vite) — copy these into `.env.local` (gitignored), not `.env`.
# Vite only exposes vars prefixed with VITE_ to client code.
# ---------------------------------------------------------------------------

# Base URL of the api-server. Empty = same-origin (uses Vite's dev proxy
# in development, or assumes the viewer is co-deployed with the api-server
# in production). Set this to a fully-qualified URL (e.g.
# "https://api.example.com") when the viewer is hosted on a different
# origin from the api-server.
VITE_CMTRACE_API_BASE=

# Entra (Azure AD) tenant ID — the GUID of the directory that owns the
# `cmtraceopen-viewer` SPA app registration. From Entra portal:
# App registrations → cmtraceopen-viewer → Overview → "Directory (tenant) ID".
VITE_ENTRA_TENANT_ID=

# Entra application (client) ID of the viewer SPA registration
# (`cmtraceopen-viewer`). From Entra portal:
# App registrations → cmtraceopen-viewer → Overview → "Application (client) ID".
VITE_ENTRA_CLIENT_ID=

# Full scope string the viewer requests when acquiring an access token for
# the api-server. Format: api://<api-client-id>/CmtraceOpen.Query
# Where <api-client-id> is the application (client) ID of the
# `cmtraceopen-api` registration (the protected-resource app).
# See docs/provisioning/02-entra-app-registration.md for the full setup.
VITE_ENTRA_API_SCOPE=

# When any of the three VITE_ENTRA_* vars above is empty, the viewer runs
# in **anonymous mode**: no MSAL initialization, no Authorization header
# attached to api-server requests. This works against api-server with
# CMTRACE_AUTH_MODE=disabled (dev bypass).

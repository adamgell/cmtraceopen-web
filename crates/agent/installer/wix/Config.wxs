<?xml version="1.0" encoding="UTF-8"?>
<!--
  Config.wxs — Runtime data components for CMTraceOpenAgent.

  Owns:
  - %ProgramData%\CMTraceOpen\Agent\config.toml  (default config, NeverOverwrite)
  - %ProgramData%\CMTraceOpen\Agent\Queue\        (empty dir, ACL set)
  - %ProgramData%\CMTraceOpen\Agent\logs\         (empty dir, ACL set)

  Design constraints (§4, §7, §8):
  - config.toml:  NeverOverwrite="yes" so operator edits survive upgrades.
                  Permanent="yes" so uninstall does NOT delete it (operator
                  data convention; use KEEP_USER_DATA=0 for full purge).
  - Queue/ + logs/ directories are created with CreateFolder; no file payload
                  so MSI never touches their contents during upgrade.
  - ACL grants on Queue/ and logs/:
                  LocalSystem: Full Control (the service account)
                  Administrators: Full Control (admin tooling)
                  Users: Read (forensic snapshots without elevation)
                  See design §4 for the Users:R rationale.

  NOTE: The ProgramData directory tree is NOT removed on standard uninstall —
  that is intentional. Product.wxs owns the KEEP_USER_DATA=0 purge path via
  util:RemoveFolderEx; this file only creates and populates the directories.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <?include Variables.wxi ?>

  <Fragment>

    <!--
      Directory structure under CommonAppDataFolder (%ProgramData%).
    -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="CMTraceOpenDataRootDir" Name="CMTraceOpen">
        <Directory Id="AgentDataDir" Name="Agent">
          <Directory Id="AgentQueueDir" Name="Queue" />
          <Directory Id="AgentLogsDir" Name="logs" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!--
      AgentConfig ComponentGroup — referenced from Product.wxs Feature graph.
    -->
    <ComponentGroup Id="AgentConfig">

      <!--
        ConfigTomlComponent — default config.toml.

        NeverOverwrite="yes": if the file already exists (operator has edited
        it), MSI leaves it alone on reinstall/upgrade.

        Permanent="yes": MSI does not remove the file on uninstall. Operators
        who want a full clean-up pass KEEP_USER_DATA=0 (handled in Product.wxs
        via util:RemoveFolderEx).

        ====================================================================
        WARNING — DO NOT REMOVE Permanent="yes" WITHOUT MIGRATION PLANNING.
        ====================================================================
        Permanent="yes" is load-bearing across upgrade chains. If a future
        version drops it, MajorUpgrade Schedule="afterInstallExecute" will
        delete the operator's edited config.toml during the old-version
        cleanup phase: the new component is NeverOverwrite="yes" (which
        suppresses the *write* but NOT the *remove*), so the file would
        vanish silently. Pair any change here with a migration CA that
        backs up + restores the operator's config, or a release-notes
        callout that operators must back up config.toml before upgrade.
        See design §7 for the upgrade-sequence walkthrough.
      -->
      <!--
        NeverOverwrite + Permanent moved from File to Component in WiX v4
        (File no longer accepts these attributes). Semantics unchanged:
        the component's file is never overwritten by a future install and
        survives uninstall.
      -->
      <Component
          Id="ConfigTomlComponent"
          Guid="F7E8A6B5-C9D0-8E1F-2A3B-4C5D6E7F8A9B"
          Directory="AgentDataDir"
          NeverOverwrite="yes"
          Permanent="yes">
        <File
            Id="ConfigToml"
            Source="config.toml"
            Name="config.toml"
            KeyPath="yes" />
      </Component>

      <!--
        QueueDirComponent — creates %ProgramData%\CMTraceOpen\Agent\Queue\.

        CreateFolder with no file payload: MSI creates the directory but never
        manages any contents. The upload queue files are written at runtime by
        the agent; MSI upgrade does not touch them.

        ACLs grant LocalSystem full control (the service account), Administrators
        full control (admin tooling), and Users read-only (forensic snapshots
        without elevation — see design §4).
      -->
      <Component
          Id="QueueDirComponent"
          Guid="A8F9B7C6-D0E1-9F2A-3B4C-5D6E7F8A9B0C"
          Directory="AgentQueueDir">
        <CreateFolder>
          <util:PermissionEx
              User="LocalSystem"
              GenericAll="yes" />
          <util:PermissionEx
              User="Administrators"
              GenericAll="yes" />
          <util:PermissionEx
              User="Users"
              GenericRead="yes"
              GenericExecute="yes" />
        </CreateFolder>
        <!--
          Registry KeyPath required by WiX when a component has no file.
          Documents the Queue directory path for diagnostic purposes.
        -->
        <RegistryValue
            Root="HKLM"
            Key="SOFTWARE\CMTraceOpen\Agent"
            Name="QueueDir"
            Type="string"
            Value="[AgentQueueDir]"
            KeyPath="yes" />
      </Component>

      <!--
        LogsDirComponent — creates %ProgramData%\CMTraceOpen\Agent\logs\.

        Same rationale as QueueDirComponent: directory only, no file payload,
        same ACL grant pattern.
      -->
      <Component
          Id="LogsDirComponent"
          Guid="B9A0C8D7-E1F2-0A3B-4C5D-6E7F8A9B0C1D"
          Directory="AgentLogsDir">
        <CreateFolder>
          <util:PermissionEx
              User="LocalSystem"
              GenericAll="yes" />
          <util:PermissionEx
              User="Administrators"
              GenericAll="yes" />
          <util:PermissionEx
              User="Users"
              GenericRead="yes"
              GenericExecute="yes" />
        </CreateFolder>
        <!--
          Registry KeyPath required by WiX when a component has no file.
          Documents the logs directory path for diagnostic purposes.
        -->
        <RegistryValue
            Root="HKLM"
            Key="SOFTWARE\CMTraceOpen\Agent"
            Name="LogsDir"
            Type="string"
            Value="[AgentLogsDir]"
            KeyPath="yes" />
      </Component>

      <!--
        PurgeDataComponent — recursively removes %ProgramData%\CMTraceOpen\Agent\
        when KEEP_USER_DATA=0 is passed on uninstall.

        util:RemoveFolderEx reads the CMTRACE_PROGRAMDATA property set by the
        SetProperty in Product.wxs. When KEEP_USER_DATA=1 (the default), the
        property is empty and RemoveFolderEx does nothing, preserving operator
        config, the upload queue, and logs.

        This component has no KeyPath file — it's a permanent, keypath-less
        component whose sole job is to host the RemoveFolderEx action.
        The component is always included in the feature; the conditional
        behaviour is driven by whether CMTRACE_PROGRAMDATA is set.
      -->
      <Component
          Id="PurgeDataComponent"
          Guid="C0B1D2E3-F4A5-1B2C-3D4E-5F6A7B8C9D0E"
          Directory="AgentDataDir">
        <util:RemoveFolderEx
            Id="PurgeAgentDataDir"
            Property="CMTRACE_PROGRAMDATA"
            On="uninstall" />
        <RegistryValue
            Root="HKLM"
            Key="SOFTWARE\CMTraceOpen\Agent"
            Name="Installed"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>

    </ComponentGroup>

  </Fragment>

</Wix>

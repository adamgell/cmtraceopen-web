{
  "name": "cmtraceopen-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser log viewer for CMTrace Open — parses logs client-side via WebAssembly.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "wasm:build": "wasm-pack build cmtrace-wasm --target web --out-dir ../pkg",
    "wasm:build:node": "wasm-pack build cmtrace-wasm --target nodejs --out-dir ../pkg-node",
    "wasm:smoke": "node scripts/wasm-smoke.mjs",
    "dev": "pnpm wasm:build && vite",
    "build": "pnpm wasm:build && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm wasm:build && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.8.0",
    "@azure/msal-react": "^5.3.1",
    "@tanstack/react-virtual": "^3.13.24",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
